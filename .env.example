# ==========================================
# 环境变量配置模板
# 复制此文件为 .env 并填写实际值
# ==========================================

# PostgREST API 地址
API_BASE_URL=https://api.gonia.net/api

# API Key（Nginx 层鉴权，在 ECS 上执行 setup_api_security.sh 生成）
API_KEY=your_api_key_here

# 注意：
# 1. 不要将 .env 文件提交到 git
# 2. 短信服务已迁移到 ECS 后端，前端不需要阿里云 AccessKey
# 3. 开发环境请使用 .env.development
